{
  "manifest_version": 3,
  "name": "Zen Tab Sorter",
  "version": "3.0",
  "description": "Sorts tabs by domain and title. Hotkey: Alt+S.",
  "permissions": ["tabs", "storage"],
  "optional_permissions": ["tabGroups"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "sort-tabs": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Sort all tabs and groups by domain then title"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "action": {
    "default_title": "Sort all tabs (Alt+S) — Right-click for settings",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
